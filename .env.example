# Copy to .env, fill in, then: bun start

# Bearer token required on every MCP request. Generate with: openssl rand -hex 24
FLEET_TOKEN=

# Needed by the voice clients (/voice page and the mobile app): mints ephemeral
# Realtime session keys server-side.
OPENAI_API_KEY=

# 127.0.0.1 = loopback only (default). 0.0.0.0 = accept LAN clients, e.g. the
# mobile app on your wifi; the bearer token is then the only gate.
HOST=127.0.0.1
# PORT=8787

# Set to "off" for a read-only surface (hides spawn_worker, send_to_agent,
# reset_orchestrator).
# FLEET_CONTROL=off

# Fleet backend binary.
# MULTICLAUDE_BIN=~/go/bin/multiclaude

# Voice tuning.
# WALKIE_REALTIME_MODEL=gpt-realtime-2.1-mini
# WALKIE_REALTIME_VOICE=marin

# --- Auth (default: token mode, just FLEET_TOKEN above) ---
# Google Workspace SSO instead (see DEPLOY.md):
# AUTH_MODE=google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAIN=juisci.com
# SESSION_SECRET=   # openssl rand -hex 32
# PUBLIC_URL=https://walkie.example.com

# CLI worker backend
# WALKIE_REMOTE_CONTROL=on   # launch each worker with --remote-control (phone steering)
# CLAUDE_BIN=claude
