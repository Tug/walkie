# Bearer token required on every MCP request. Generate with: openssl rand -hex 24
FLEET_TOKEN=

# Set to "off" to hide the write tools (spawn_worker, send_to_agent, reset_orchestrator)
# FLEET_CONTROL=off

# HOST=0.0.0.0 to accept LAN clients (mobile app on your wifi)
# HOST=127.0.0.1
# PORT=8787
# MULTICLAUDE_BIN=~/go/bin/multiclaude
# Realtime voice client (page at /voice)
# OPENAI_API_KEY=
# WALKIE_REALTIME_MODEL=gpt-realtime-2.1-mini
# WALKIE_REALTIME_VOICE=marin
