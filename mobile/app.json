{
  "expo": {
    "name": "walkie",
    "slug": "walkie",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.tug.walkie",
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "walkie needs the microphone to talk to your agent fleet.",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "walkie lets you attach a photo to the conversation."
      },
      "bitcode": false
    },
    "android": {
      "package": "com.tug.walkie",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#101418",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client",
      "@config-plugins/react-native-webrtc",
      "expo-image-picker"
    ],
    "owner": "tug",
    "extra": {
      "eas": {
        "projectId": "d4ce14c0-057a-451d-8402-914141ba12f1"
      }
    }
  }
}
