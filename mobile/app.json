{
  "expo": {
    "name": "walkie",
    "slug": "walkie",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.tug.walkie",
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "walkie needs the microphone to talk to your agent fleet.",
        "UIBackgroundModes": ["audio", "voip"]
      }
    },
    "android": {
      "package": "com.tug.walkie",
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.FOREGROUND_SERVICE"],
      "adaptiveIcon": {
        "backgroundColor": "#101418",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": ["expo-dev-client", "@config-plugins/react-native-webrtc"]
  }
}
